# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is already in .gitignore.

# Google AI Studio / Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model id (kept configurable so it can be swapped without a code change)
GEMINI_MODEL=gemini-1.5-flash

# Max requests allowed per IP per minute across the AI-backed API routes
RATE_LIMIT_PER_MINUTE=20

# Optional. When set, staff-only actions (filing an incident) require an
# `Authorization: Bearer <this value>` header. Leave unset for the default
# open demo experience — see README "Security" section.
OPERATOR_API_KEY=
